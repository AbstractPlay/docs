{% macro renderNavTree(items, sectionUrl) %}
<ul class="subnav">
  {% for item in items %}
  <li data-depth="{{ item.depth }}">
    {% set isActive = page.url == item.url %}
    {% set isAncestor = item.url and page.url and page.url != item.url and page.url.indexOf(item.url) == 0 %}
    {% set isGroupAncestor = not item.url and item.slug and page.url and page.url.indexOf(sectionUrl + item.slug + '/') == 0 %}
    {% if item.url %}
    <a href="{{ item.url }}"{% if isActive %} class="active"{% elif isAncestor %} class="active-ancestor"{% endif %}>{{ item.title }}</a>
    {% else %}
    <span class="nav-group{% if isGroupAncestor %} active-ancestor{% endif %}">{{ item.title }}</span>
    {% endif %}
    {% if item.children and item.children.length %}
    {{ renderNavTree(item.children, sectionUrl) }}
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% endmacro %}

<nav class="site-nav" aria-label="Documentation">
  <ul>
    {% for item in navigation %}
    <li>
      <a href="{{ item.url }}"{% if page.url == item.url or page.url and page.url.indexOf(item.url) == 0 and item.url != '/' %} class="active"{% endif %}>{{ item.title }}</a>
      {% if item.children and page.url and page.url.indexOf(item.url) == 0 and item.url != '/' %}
      {{ renderNavTree(item.children, item.url) }}
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</nav>
